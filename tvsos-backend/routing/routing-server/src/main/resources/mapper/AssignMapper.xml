<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.tvsos.mapper.AssignMapper">

    <insert id="insert" parameterType="entity.Assign" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO assign
            (vehicle_id, driver_id, transport_order_id)
        VALUES
            (#{vehicleId}, #{driverId}, #{transportOrderId})
    </insert>

    <select id="findByVehicleId" parameterType="java.lang.Long" resultType="entity.Assign">
        SELECT * FROM assign WHERE vehicle_id = #{vehicleId}
    </select>

    <update id="update" parameterType="entity.Assign">
        UPDATE assign
        <set>
            <if test="driverId != null">
                driver_id = #{driverId},
            </if>
            <if test="transportOrderId != null">
                transport_order_id = #{transportOrderId}
            </if>
        </set>
        WHERE id = #{id}
    </update>
</mapper>