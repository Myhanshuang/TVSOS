<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.tvsos.mapper.CargoMapper">
    <select id="findByType" parameterType="java.lang.Integer" resultType="entity.Cargo">
        SELECT
            *
        FROM
            cargo
        WHERE
            tybe = #{tybe}
    </select>

    <select id="list" resultType="entity.Cargo">
        SELECT * FROM cargo
    </select>
</mapper>
