<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.tvsos.mapper.OrderDetailMapper">

    <insert id="insert" parameterType="entity.OrderDetail" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO order_detail
            (transport_order_id, cargo_id, quantity, status)
        VALUES
            (#{transportOrderId}, #{cargoId}, #{quantity}, #{status})
    </insert>

    <select id="findByTransportOrderId" parameterType="java.lang.Long" resultType="entity.OrderDetail">
        SELECT * FROM order_detail WHERE transport_order_id = #{transportOrderId}
    </select>

    <select id="findByStatus" parameterType="java.lang.Integer" resultType="entity.OrderDetail">
        SELECT * FROM order_detail WHERE status = #{status}
    </select>

    <update id="update" parameterType="entity.OrderDetail">
        UPDATE order_detail
        <set>
            <if test="status != null">
                status = #{status}
            </if>
        </set>
        WHERE id = #{id}
    </update>
</mapper>